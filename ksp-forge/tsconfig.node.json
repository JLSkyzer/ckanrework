{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "types": ["node"],
    "lib": ["ESNext"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "out"
  },
  "include": ["electron/**/*.ts", "vite.config.ts", "tailwind.config.ts"]
}
